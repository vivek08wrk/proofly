    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/mongoose": "^5.11.96",
    "@types/sharp": "^0.31.1",
    "@types/socket.io": "^3.0.1",
    "@types/unzipper": "^0.10.11",
    "@types/uuid": "^10.0.0",
    "tsc-alias": "^1.8.9",
    "tsx": "^4.22.3"
